# ──────────────────────────────────────────────────────────
#  Software Security Provenance Chain — Environment Config
# ──────────────────────────────────────────────────────────

# Hedera Testnet JSON-RPC Relay (HashIO public endpoint)
# You can also use: https://pool.arkhia.io/hedera/testnet/json-rpc/v1/<API_KEY>
HEDERA_TESTNET_ENDPOINT=https://testnet.hashio.io/api

# Deployer private key (ECDSA hex, WITHOUT 0x prefix or WITH 0x prefix — both work)
# Generate via Hedera Portal: https://portal.hedera.com/
# Fund your account with testnet HBAR from the portal faucet.
DEPLOYER_PRIVATE_KEY=your_ecdsa_private_key_here