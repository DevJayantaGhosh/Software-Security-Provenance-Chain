# ──────────────────────────────────────────────────────────
#  Software Security Provenance Chain — Environment Config
# ──────────────────────────────────────────────────────────

# Hedera Testnet JSON-RPC Relay
HEDERA_TESTNET_ENDPOINT=https://testnet.hashio.io/api

# ──────────────────────────────────────────────────────────
#  HEDERA ACCOUNT (used as deployer & service account)
# ──────────────────────────────────────────────────────────
# This SAME key is used for:
#   1. Deploying the contract (owner)
#   2. Service account (recording products on-chain)
#   3. Frontend (set as VITE_SERVICE_ACCOUNT_PRIVATE_KEY in the frontend .env)
#
# How to get it:
#   1. Go to https://portal.hedera.com/
#   2. Create/login to your account
#   3. Copy "ECDSA Private Key" (DER Hex or Raw Hex)
#   4. Fund with testnet HBAR from the portal faucet
#
SERVICE_ACCOUNT_PRIVATE_KEY=your_hedera_ecdsa_private_key_here
